# ============================================================
# Leafleter Backend Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---------------------------
# Core Application
# ---------------------------
ENVIRONMENT=development
DEBUG=False
PROJECT_NAME=Leafleter
VERSION=0.1.0

# ---------------------------
# Security / JWT
# ---------------------------
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=14400
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ---------------------------
# Database
# ---------------------------
DATABASE_URL=sqlite+aiosqlite:///./leafleter.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=False

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/leafleter

# ---------------------------
# Redis
# ---------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------
# CORS
# ---------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------
# Object Storage (local / S3 / MinIO)
# ---------------------------
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET=leafleter
OBJECT_STORAGE_REGION=us-east-1
LOCAL_STORAGE_PATH=./storage

# ---------------------------
# Scheduler
# ---------------------------
SCHEDULER_ENABLED=True
SCHEDULER_JOBSTORE_URL=

# ---------------------------
# Search Providers
# ---------------------------
SERPAPI_API_KEY=
BING_API_KEY=
TAVILY_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# ---------------------------
# AI Providers (global fallbacks)
# ---------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
KIMI_API_KEY=
QWEN_API_KEY=

# ---------------------------
# SMTP / Email Notifications
# ---------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---------------------------
# Logging
# ---------------------------
LOG_LEVEL=INFO
LOG_JSON=False

# ---------------------------
# Rate Limiting
# ---------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------
# Frontend URL
# ---------------------------
FRONTEND_URL=http://localhost:5173

# ---------------------------
# Intelligence Core
# ---------------------------
INTELLIGENCE_DB_PATH=data/intelligence.db
ENABLE_INTELLIGENCE_CORE=true
ENABLE_AUTO_WORKFLOWS=true
ENABLE_SMART_ALERTS=true
ENABLE_AUTO_REPORTS=true
ENABLE_ACTION_AI_GENERATION=false
DAILY_PULSE_HOUR=9
DAILY_PULSE_TIMEZONE=UTC
TOPIC_ANOMALITY_THRESHOLD_PCT=20
COMPETITOR_MENTION_THRESHOLD=2
ALERT_AGGREGATION_HOURS=24
REPORT_TRIGGER_ALERT_COUNT=3
CONTEXT_MEMORY_MAX_EVENTS=50
WORKFLOW_RETRY_ATTEMPTS=3
PRIORITY_QUEUE_MAX_SIZE=50
INTELLIGENCE_AI_MODEL=gpt-4
ACTION_GENERATION_MAX_PER_EVENT=3
